---
import { Image } from "@astrojs/image/components";
import config from "@config/config.json";

const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
---

<div class="order-0 flex items-center">
  <a href="/" class="navbar-brand flex items-center">
    <svg class="w-12 fill-yellow-400 transition-transform hover:rotate-[10deg] hover:opacity-50" viewBox="59.1 143.5 356.1 222.6">
      <path d="m103.6 143.5 133.6 89 133.5-89-1.4 1 45.9 177h-89l-44.5-44.4-44.5 89-44.6-89-44.5 44.5h-89l46-177.1-1.5-1Z"/>
    </svg>
    <span class="ml-2 whitespace-nowrap text-yellow-400 text-2xl">{logo_text}</span>
  </a>
</div>